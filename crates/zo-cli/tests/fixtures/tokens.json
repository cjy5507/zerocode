{
  "$schema": "zo-tui-tokens-v1",
  "meta": {
    "project": "zo-tui-migration",
    "target": "ratatui 0.29 + crossterm",
    "reference_aesthetic": "@anthropic-ai/claude-code CLI, opencode",
    "notes": [
      "Terminal has no px; spacing is in cells, typography is style+fg not size.",
      "Every semantic role has a parallel no_color style-only variant (NO_COLOR env).",
      "ASSUMPTION labels mark values inferred from Claude Code CLI behavior without source confirmation."
    ]
  },

  "color": {
    "primary": {
      "accent":       { "hex": "#D97757", "ansi256": 173, "role": "Anthropic clay / Claude brand accent",             "assumption": "ASSUMPTION: Claude Code uses the Anthropic clay orange (~#D97757) for prompt glyphs and focus underlines." },
      "accent_dim":   { "hex": "#A85A3E", "ansi256": 137, "role": "Dim variant of accent, used for inactive borders" }
    },
    "secondary": {
      "cyan":         { "hex": "#6EC1E4", "ansi256":  75, "role": "Info / model badge / cwd path" },
      "violet":       { "hex": "#9B87F5", "ansi256": 141, "role": "Reasoning block (Anthropic thinking / OpenAI reasoning), MCP indicator" },
      "teal":         { "hex": "#3FB8AF", "ansi256":  43, "role": "Git branch" }
    },
    "neutral": {
      "bg":           { "hex": null,      "ansi": "reset", "role": "Terminal default background — never set, respects user theme." },
      "fg":           { "hex": "#E6E6E6", "ansi256": 254, "role": "Default body foreground" },
      "bright":       { "hex": "#FFFFFF", "ansi256": 255, "role": "Bold/heading foreground" },
      "dim":          { "hex": "#8A8A8A", "ansi256": 245, "role": "Dim body (hints, thinking, secondary HUD fields)" },
      "muted":        { "hex": "#5F5F5F", "ansi256": 240, "role": "Muted (borders, separators, collapsed previews)" },
      "faint":        { "hex": "#3A3A3A", "ansi256": 237, "role": "Faint (disabled, placeholders)" }
    },
    "semantic": {
      "success":      { "hex": "#7FBF7F", "ansi256": 114, "role": "ok badges, diff add gutter fg" },
      "warn":         { "hex": "#E5C07B", "ansi256": 179, "role": "warning, running spinner" },
      "error":        { "hex": "#E06C75", "ansi256": 203, "role": "error badges, diff remove gutter fg, is_error tool result" },
      "info":         { "hex": "#6EC1E4", "ansi256":  75, "role": "info banners, /system messages" }
    },
    "syntax": {
      "keyword":      { "hex": "#C678DD", "ansi256": 170 },
      "string":       { "hex": "#98C379", "ansi256": 114 },
      "number":       { "hex": "#D19A66", "ansi256": 173 },
      "comment":      { "hex": "#5C6370", "ansi256": 240, "style": "italic" },
      "function":     { "hex": "#61AFEF", "ansi256":  75 },
      "type":         { "hex": "#E5C07B", "ansi256": 179 },
      "punctuation":  { "hex": "#ABB2BF", "ansi256": 249 }
    },
    "diff": {
      "add_fg":       { "hex": "#7FBF7F", "ansi256": 114 },
      "add_bg":       { "hex": "#1E3320", "ansi256":  22, "assumption": "ASSUMPTION: subtle green wash; terminal themes vary, keep bg optional." },
      "remove_fg":    { "hex": "#E06C75", "ansi256": 203 },
      "remove_bg":    { "hex": "#3A1E1E", "ansi256":  52 },
      "context_fg":   { "hex": "#8A8A8A", "ansi256": 245 },
      "hunk_header":  { "hex": "#6EC1E4", "ansi256":  75, "style": "bold" },
      "file_header":  { "hex": "#E5C07B", "ansi256": 179, "style": "bold" }
    },
    "permission_mode": {
      "RO":  { "fg": "#7FBF7F", "ansi256": 114, "label": "RO",  "desc": "read-only" },
      "WS":  { "fg": "#E5C07B", "ansi256": 179, "label": "WS",  "desc": "workspace write" },
      "ALL": { "fg": "#E06C75", "ansi256": 203, "label": "ALL", "desc": "all tools, dangerous" }
    }
  },

  "typography": {
    "fontFamily": { "note": "Terminal-controlled. No override." },
    "roles": {
      "body":        { "style": [],                     "fg": "neutral.fg" },
      "dim":         { "style": ["dim"],                "fg": "neutral.dim" },
      "bold":        { "style": ["bold"],               "fg": "neutral.bright" },
      "italic":      { "style": ["italic"],             "fg": "neutral.fg" },
      "code_inline": { "style": [],                     "fg": "syntax.string", "bg_hint": "inverse-subtle" },
      "code_block":  { "style": [],                     "fg": "neutral.fg" },
      "heading_1":   { "style": ["bold"],               "fg": "primary.accent" },
      "heading_2":   { "style": ["bold"],               "fg": "secondary.cyan" },
      "heading_3":   { "style": ["bold","underlined"],  "fg": "neutral.bright" },
      "link":        { "style": ["underlined"],         "fg": "secondary.cyan" },
      "placeholder": { "style": ["dim","italic"],       "fg": "neutral.faint" },
      "key_hint":    { "style": ["dim"],                "fg": "neutral.dim" },
      "badge":       { "style": ["bold","reversed"],    "fg": "<contextual>" }
    }
  },

  "spacing": {
    "unit": "cell",
    "row_gap":       1,
    "block_gap":     1,
    "card_padding_x": 1,
    "card_padding_y": 0,
    "indent":        2,
    "gutter":        2,
    "hud_sep":       1,
    "modal_padding_x": 2,
    "modal_padding_y": 1
  },

  "borderRadius": {
    "note": "Ratatui border sets — there is no pixel radius.",
    "none":    "BorderType::Plain, Borders::NONE",
    "single":  "BorderType::Plain",
    "rounded": "BorderType::Rounded",
    "double":  "BorderType::Double",
    "thick":   "BorderType::Thick"
  },

  "border_usage": {
    "transcript":       "none",
    "input_box":        "rounded",
    "hud":              "none",
    "tool_call_card":   "rounded",
    "tool_result_card": "rounded",
    "diff_card":        "rounded",
    "permission_card":  "thick",
    "reasoning_block":  "none",
    "modal":            "rounded",
    "error_card":       "thick"
  },

  "shadow": {
    "note": "Terminals have no shadows. Depth is expressed via border style + bg inversion on modals."
  },

  "elevation": {
    "flat":    { "border": "none",    "fg": "neutral.fg" },
    "raised":  { "border": "rounded", "fg": "neutral.fg" },
    "modal":   { "border": "rounded", "fg": "neutral.bright", "dim_backdrop": true },
    "urgent":  { "border": "thick",   "fg": "semantic.error" }
  },

  "breakpoint": {
    "unit": "columns",
    "narrow":  { "max":  59, "label": "narrow"  },
    "compact": { "min":  60, "max": 99, "label": "compact" },
    "wide":    { "min": 100,            "label": "wide"    }
  },

  "hud_field_visibility": {
    "wide_ge_100":    ["model", "ctx", "cost", "cwd", "git", "mode", "mcp"],
    "compact_80_99":  ["model", "ctx", "cost",         "git", "mode", "mcp"],
    "compact_60_79":  ["model", "ctx",                         "mode", "mcp"],
    "narrow_lt_60":   ["model", "ctx",                         "mode"],
    "degradation_order_drop": ["cwd", "cost", "mcp", "git"],
    "separator": "  │  ",
    "separator_narrow": " │ "
  },

  "model_field": {
    "format_wide":    "{provider}:{alias}",
    "format_compact": "{provider}:{alias}",
    "format_narrow":  "{alias}",
    "provider_color": {
      "claude": "primary.accent",
      "codex":  "secondary.cyan",
      "gemini": "secondary.violet",
      "local":  "neutral.dim",
      "unknown":"neutral.fg"
    },
    "provider_glyph": {
      "claude": "◆",
      "codex":  "◇",
      "gemini": "✦",
      "local":  "·",
      "ascii_fallback": { "claude": "A", "codex": "O", "gemini": "G", "local": "." }
    },
    "separator_char": ":",
    "separator_style": ["dim"],
    "alias_style":    [],
    "notes": "Provider segment colored via provider_color; alias segment inherits neutral.fg. In narrow breakpoint the provider prefix is dropped entirely, alias only. In no_color mode, provider glyph becomes the prefix (e.g. 'A claude:opus' collapses to 'A opus')."
  },

  "hud_field_color": {
    "model":  "model_field.provider_color.<current>",
    "ctx":    "neutral.fg",
    "cost":   "semantic.warn",
    "cwd":    "secondary.cyan",
    "git":    "secondary.teal",
    "mode":   "permission_mode.<current>",
    "mcp":    "secondary.violet"
  },

  "no_color": {
    "strategy": "Drop all fg/bg. Replace color signals with style (bold/dim/reversed/underlined) and textual prefixes.",
    "roles": {
      "primary.accent":  { "style": ["bold"] },
      "secondary.cyan":  { "style": ["underlined"] },
      "secondary.violet":{ "style": ["italic"] },
      "secondary.teal":  { "style": ["italic"] },
      "neutral.dim":     { "style": ["dim"] },
      "neutral.bright":  { "style": ["bold"] },
      "semantic.success":{ "style": ["bold"],    "prefix": "[ok] " },
      "semantic.warn":   { "style": ["bold"],    "prefix": "[!] " },
      "semantic.error":  { "style": ["bold","reversed"], "prefix": "[x] " },
      "semantic.info":   { "style": ["dim"],     "prefix": "[i] " },
      "diff.add_fg":     { "style": [],          "prefix": "+" },
      "diff.remove_fg":  { "style": [],          "prefix": "-" },
      "diff.context_fg": { "style": ["dim"],     "prefix": " " },
      "permission_mode.RO":  { "style": ["bold"],            "label": "[RO]"  },
      "permission_mode.WS":  { "style": ["bold"],            "label": "[WS]"  },
      "permission_mode.ALL": { "style": ["bold","reversed"], "label": "[ALL]" }
    }
  },

  "glyphs": {
    "spinner": {
      "set": ["⠋","⠙","⠹","⠸","⠼","⠴","⠦","⠧","⠇","⠏"],
      "fallback_ascii": ["|","/","-","\\"],
      "interval_ms": 80,
      "assumption": "ASSUMPTION: Claude Code CLI uses a braille spinner similar to ora's 'dots'. Exact set not confirmed; braille dots are the defensible default."
    },
    "prompt_user":        "> ",
    "prompt_assistant":   "⏺ ",
    "bullet":             "•",
    "arrow_right":        "›",
    "ellipsis":           "…",
    "chevron_collapsed":  "▸",
    "chevron_expanded":   "▾",
    "check":              "✓",
    "cross":              "✗",
    "separator_hud":      "│",
    "corner_tl":          "╭",
    "corner_tr":          "╮",
    "corner_bl":          "╰",
    "corner_br":          "╯",
    "ascii_fallback": {
      "prompt_assistant":  "* ",
      "bullet":            "*",
      "chevron_collapsed": ">",
      "chevron_expanded":  "v",
      "check":             "[ok]",
      "cross":             "[x]",
      "separator_hud":     "|",
      "corner_tl":"+", "corner_tr":"+", "corner_bl":"+", "corner_br":"+"
    }
  },

  "a11y": {
    "min_contrast_ratio_text": 4.5,
    "focus_indicator": "reversed + accent fg border",
    "keyboard_only": true,
    "touch_target_cells_min": 1,
    "respect_env": ["NO_COLOR", "TERM=dumb"],
    "dumb_terminal_strategy": "no borders, ASCII glyphs, style-only"
  }
}
